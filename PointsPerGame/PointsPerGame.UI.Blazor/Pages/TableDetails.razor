@page "/tables/{leagueId:int}"
@using PointsPerGame.Core.DTOs
@inject Services.TablesService TablesService

<h3>League Table</h3>

@if (rows == null)
{
    <p>Loading...</p>
}
else if (rows.Count < 10)
{
    // TODO - this indicates an issue with the league page, as there are at least 10 teams in all the leagues
    <Missing Message="League page not found or data unavailable."/>
}
else
{
    <table class="teamTable">
        <thead>
        <tr>
            <th></th>
            <th>Team</th>
            <th>P</th>
            <th>W</th>
            <th>D</th>
            <th>L</th>
            <th>GF</th>
            <th>GA</th>
            <th>GD</th>
            <th>Pts</th>
            <th>PPG</th>
        </tr>
        </thead>
        <tbody>
        @foreach (var r in rows)
        {
            <tr>
                <td><img src="@r.TeamCrest" alt="Not found" /></td>
                <td><a href="@r.TeamUrl" target="_blank">@r.TeamName</a></td>
                <td>@r.Played</td>
                <td>@r.Won</td>
                <td>@r.Drawn</td>
                <td>@r.Lost</td>
                <td>@r.GoalsScored</td>
                <td>@r.GoalsConceded</td>
                <td>@r.GoalDifference</td>
                <td>@r.Points</td>
                <td>@r.PointsPerGame</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {

    [Parameter]
    public int LeagueId { get; set; }

    private IReadOnlyList<TableRowDto>? rows;

    protected override async Task OnParametersSetAsync()
    {
        rows = await TablesService.GetLeagueTableAsync(LeagueId);
    }

}

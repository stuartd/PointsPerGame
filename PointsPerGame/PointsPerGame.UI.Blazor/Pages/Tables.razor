@page "/"
@page "/tables"
@using PointsPerGame.UI.Blazor.Services

<PageTitle>Points Per Game</PageTitle>

<h1>Points Per Game</h1>
<p class="lede">Football tables sorted by points per game, then games played, goal difference, and team name.</p>

@if (links == null)
{
    <p>Loading...</p>
}
else
{
    <section aria-labelledby="tables-heading">
        <h2 id="tables-heading">Available Tables</h2>
        <ul class="league-links">
            @foreach (var kv in links)
            {
                <li>
                    <a href="/tables/@kv.Key">@kv.Value</a>
                </li>
            }
        </ul>
    </section>

    <section aria-labelledby="sorting-heading">
        <h2 id="sorting-heading">Sorting</h2>
        <p>Teams are sorted by points per game, then by the number of games played. If both values are equal, teams are sorted by goal difference, then by team name.</p>
    </section>
}

@code {
    private IReadOnlyDictionary<int, string>? links;

    protected override async Task OnInitializedAsync()
    {
        links = await TablesService.GetLeagueLinksAsync();
    }
}

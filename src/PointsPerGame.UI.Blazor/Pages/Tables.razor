@page "/"
@page "/tables"
@using PointsPerGame.UI.Blazor.Services

<PageTitle>Points Per Game</PageTitle>

<h1>Points Per Game</h1>
<p class="lede">Teams are sorted by points per game, then by the number of games played. If both values are equal, teams are sorted by goal difference, then by team name.</p>

@if (links == null)
{
    <p>Loading...</p>
}
else
{
    <section aria-labelledby="tables-heading">
        <h2 id="tables-heading">Available Tables</h2>
        <table class="available-tables">
            <thead>
            <tr>
                <th>Table</th>
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var kv in links)
            {
                <tr>
                    <td>@kv.Value</td>
                    <td><a href="/tables/@kv.Key">View</a></td>
                </tr>
            }
            </tbody>
        </table>
    </section>

    <section aria-labelledby="data-heading">
        <h2 id="data-heading">Data</h2>
        <p>TThe data is scraped from the Guardian website</p>
    </section>
}

@code {
    private IReadOnlyDictionary<int, string>? links;

    protected override async Task OnInitializedAsync()
    {
        links = await TablesService.GetLeagueLinksAsync();
    }
}

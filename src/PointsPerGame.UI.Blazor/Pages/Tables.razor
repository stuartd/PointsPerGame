@page "/"
@page "/tables"
@using PointsPerGame.UI.Blazor.Services

<PageTitle>Points Per Game</PageTitle>

<h1>Points Per Game</h1>
34
<h2>Available Tables</h2>

@if (links == null)
{
    <p>Loading...</p>
}
else
{
    @foreach (var kv in links)
    {
        <a href="/tables/@kv.Key">@kv.Value</a>
        <br />
    }

    <h2>Sorting</h2>
    <text>Teams are sorted by points per game.</text>
    <br />
    <text>Teams with a perfect record are then sorted by goal difference; other points-per-game ties favour fewer games played.</text>
    <br />
    <text>Remaining ties are resolved by goal difference, points, then team name.</text>
    <br />

    <br />

    <a href="https://github.com/stuartd/PointsPerGame">Site code (GitHub)</a>

    <br />

    <a href="https://github.com/stuartd/PointsPerGame/issues">Having a problem? Got any ideas for enhancements? Let me know! (GitHub)</a>
}

@code {
    private IReadOnlyDictionary<int, string>? links;

    protected override async Task OnInitializedAsync()
    {
        links = await TablesService.GetLeagueLinksAsync();
    }
}

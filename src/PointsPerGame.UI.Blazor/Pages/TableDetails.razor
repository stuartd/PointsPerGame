@page "/tables/{leagueId:int}"
@using PointsPerGame.Core.DTOs
@using PointsPerGame.UI.Blazor.Services
@inject Services.TablesService TablesService

<PageTitle>@PageTitle</PageTitle>

<h1>
    @if (sourceUrl == null)
    {
        @PageTitle
    }
    else
    {
        <a href="@sourceUrl" target="_blank" rel="noopener noreferrer">@PageTitle</a>
    }
</h1>

@if (rows == null)
{
    <p>Loading...</p>
}
else if (errorMessage != null)
{
    <Missing Message="@errorMessage"/>
}
else
{
    <div class="table-scroll">
        <table class="teamTable">
            <thead>
            <tr>
                <th></th>
                <th>Team</th>
                <th>
                    <abbr class="stat-label-short" title="Played">P</abbr>
                    <span class="stat-label-long">Played</span>
                </th>
                <th>
                    <abbr class="stat-label-short" title="Won">W</abbr>
                    <span class="stat-label-long">Won</span>
                </th>
                <th>
                    <abbr class="stat-label-short" title="Drawn">D</abbr>
                    <span class="stat-label-long">Drawn</span>
                </th>
                <th>
                    <abbr class="stat-label-short" title="Lost">L</abbr>
                    <span class="stat-label-long">Lost</span>
                </th>
                <th>
                    <abbr class="stat-label-short" title="Goals For">GF</abbr>
                    <span class="stat-label-long">Goals For</span>
                </th>
                <th>
                    <abbr class="stat-label-short" title="Goals Against">GA</abbr>
                    <span class="stat-label-long">Goals Against</span>
                </th>
                <th>
                    <abbr class="stat-label-short" title="Goal Difference">GD</abbr>
                    <span class="stat-label-long">Goal Diff</span>
                </th>
                <th>
                    <abbr class="stat-label-short" title="Points">Pts</abbr>
                    <span class="stat-label-long">Points</span>
                </th>
                <th>
                    <abbr class="stat-label-short" title="Points Per Game">PPG</abbr>
                    <span class="stat-label-long">Points/Game</span>
                </th>
            </tr>
            </thead>
            <tbody>
            @foreach (var r in rows)
            {
                <tr>
                    <td><img src="@r.TeamCrest" alt="" /></td>
                    <td><a href="@r.TeamUrl">@r.TeamName</a></td>
                    <td>@r.Played</td>
                    <td>@r.Won</td>
                    <td>@r.Drawn</td>
                    <td>@r.Lost</td>
                    <td>@r.GoalsScored</td>
                    <td>@r.GoalsConceded</td>
                    <td>@r.GoalDifference</td>
                    <td>@r.Points</td>
                    <td>@r.PointsPerGame</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter]
    public int LeagueId { get; set; }

    private IReadOnlyList<TableRowDto>? rows;
    private string? leagueName;
    private string? errorMessage;
    private string? sourceUrl;

    private string PageTitle => leagueName == null ? "League Table" : $"{leagueName} Table";

    protected override async Task OnParametersSetAsync()
    {
        rows = null;
        errorMessage = null;
        leagueName = TablesService.GetLeagueName(LeagueId);
        sourceUrl = TablesService.GetLeagueSourceUrl(LeagueId);

        if (leagueName == null)
        {
            errorMessage = "Table not found.";
            rows = [];
            return;
        }

        try
        {
            rows = await TablesService.GetLeagueTableAsync(LeagueId);

            if (rows.Count < 10)
            {
                errorMessage = "League page not found or data unavailable.";
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "The table could not be loaded right now.";
            rows = [];
        }
        catch (InvalidOperationException)
        {
            errorMessage = "League page not found or data unavailable.";
            rows = [];
        }
    }
}

